WORDPRESS_API_URL=https://your-wordpress-site.com/wp-json/wp/v2
# Production: https://ftiaxesite.gr — local dev can use http://localhost:4321
SITE_URL=https://ftiaxesite.gr
SITE_NAME=ftiaxesite.gr

# Sanity (public read — safe in browser)
PUBLIC_SANITY_PROJECT_ID=29vmuk87
PUBLIC_SANITY_DATASET=production

# Google Tag Manager (public container ID, e.g. GTM-XXXXXXX). Loads on every page via SiteLayout.
PUBLIC_GTM_ID=

# Optional: direct GA4 only when GTM is not set — configure GA4 inside GTM when PUBLIC_GTM_ID is used.
PUBLIC_GA4_MEASUREMENT_ID=

# --- Server-only (never expose with PUBLIC_ prefix) ---

# Sanity token with create permission for formSubmission documents
SANITY_WRITE_TOKEN=your-sanity-write-token

# Resend (https://resend.com) — admin notification emails
RESEND_API_KEY=re_xxxxxxxx

# Inbox that receives new form submission alerts
ADMIN_NOTIFICATION_EMAIL=you@example.com

# Optional: Studio URL for deep links in notification emails
SANITY_STUDIO_URL=https://ftiaxesite.sanity.studio

# Cal.com API key for /api/bookings proxy (Studio Bookings tool)
CAL_COM_API_KEY=cal_live_xxxxxxxx

# Google reCAPTCHA v3 (invisible; site key is public; secret is server-only)
PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Optional score threshold 0.0-1.0 (default 0.5)
# RECAPTCHA_MIN_SCORE=0.5
