---
import FluentFormEmbed from '../../components/FluentFormEmbed.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { fetchPageFields, fetchPageSeoData, pageField } from '../../lib/cms';
import { resolvePageLocale } from '../../lib/i18n';

const locale = resolvePageLocale(Astro.currentLocale);
const fields = await fetchPageFields('contact', locale);
const seoData = await fetchPageSeoData('contact', locale);

const heroTitle = pageField(fields, 'fti_contact_hero_title', 'Επικοινωνία');
const heroDescription = pageField(
  fields,
  'fti_contact_hero_description',
  'Έχεις ερώτηση ή θέλεις να μιλήσουμε για το project σου; Στείλε μας μήνυμα — θα σου απαντήσουμε το συντομότερο δυνατό.',
);

const email = pageField(fields, 'fti_contact_email', 'info@ftiaxesite.gr');
const phone = pageField(fields, 'fti_contact_phone', '');
const location = pageField(fields, 'fti_contact_location', 'Αθήνα, Ελλάδα');
const hours = pageField(fields, 'fti_contact_hours', 'Δευτέρα – Παρασκευή: 10:00 – 18:00\nΣάββατο – Κυριακή: Κλειστά');

const formTitle = pageField(fields, 'fti_contact_form_title', 'Στείλε μας μήνυμα');
const formShortcode = pageField(fields, 'fti_contact_form_shortcode');
const formSubmitNote = pageField(
  fields,
  'fti_contact_form_submit_note',
  'Θα λάβεις απάντηση εντός 1–2 εργάσιμων ημερών.',
);

const contactItems = [
  email
    ? {
        icon: 'alternate_email',
        label: 'Email',
        value: email,
        href: `mailto:${email}`,
      }
    : null,
  phone
    ? {
        icon: 'call',
        label: 'Τηλέφωνο',
        value: phone,
        href: `tel:${phone.replace(/\s+/g, '')}`,
      }
    : null,
  location
    ? {
        icon: 'location_on',
        label: 'Τοποθεσία',
        value: location,
        href: null,
      }
    : null,
].filter((item): item is NonNullable<typeof item> => item !== null);
---

<SiteLayout
  canonicalPath="/contact/"
  description="Επικοινωνήστε με το ftiaxesite.gr για web design, Astro και WordPress headless projects."
  locale={locale}
  seoData={seoData}
  title="Επικοινωνία"
>
  <div class="mx-auto max-w-container-max-width px-margin-mobile py-12 md:px-margin-desktop md:py-24">
    <section class="mb-16 max-w-3xl text-center md:mb-20 md:text-left">
      <h1 class="mb-6 font-headline-lg text-headline-lg-mobile leading-tight text-on-surface md:text-headline-lg">
        {heroTitle}
      </h1>
      <p class="font-body-lg text-body-lg leading-relaxed text-on-surface-variant">{heroDescription}</p>
    </section>

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[38%_62%]">
      <aside class="order-2 space-y-8 lg:order-1">
        <div class="rounded-lg border border-outline-variant/30 bg-surface-container-low p-8 md:p-10">
          <h2 class="mb-8 font-headline-sm text-headline-sm text-on-surface">Στοιχεία επικοινωνίας</h2>
          <div class="space-y-6">
            {
              contactItems.map((item) => (
                <div class="flex gap-4">
                  <span class="material-symbols-outlined text-primary">{item.icon}</span>
                  <div>
                    <p class="font-label-md text-label-md uppercase tracking-wider text-on-surface-variant">{item.label}</p>
                    {
                      item.href ? (
                        <a class="font-body-md text-body-md text-on-surface transition-colors hover:text-primary" href={item.href}>
                          {item.value}
                        </a>
                      ) : (
                        <p class="font-body-md text-body-md text-on-surface whitespace-pre-line">{item.value}</p>
                      )
                    }
                  </div>
                </div>
              ))
            }
          </div>
          {
            hours ? (
              <div class="mt-10 border-t border-outline-variant/20 pt-8">
                <h3 class="mb-4 font-label-lg text-label-lg text-on-surface">Ωράριο</h3>
                <p class="font-body-md text-body-md whitespace-pre-line text-on-surface-variant">{hours}</p>
              </div>
            ) : null
          }
        </div>
      </aside>

      <section class="order-1 lg:order-2">
        <div class="rounded-lg border border-outline-variant/30 bg-surface-container-lowest p-8 shadow-sm md:p-12">
          <h2 class="mb-8 font-headline-md text-headline-md text-on-surface">{formTitle}</h2>
          <FluentFormEmbed locale={locale} shortcode={formShortcode}>
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                  <div class="space-y-2">
                    <label class="font-label-md text-on-surface-variant" for="contact-name">Όνοματεπώνυμο *</label>
                    <input
                      class="w-full rounded-DEFAULT border border-outline-variant bg-surface-container-low px-4 py-3 text-body-md outline-none transition-all focus:border-primary focus:ring-1 focus:ring-primary"
                      id="contact-name"
                      name="name"
                      required
                      type="text"
                    />
                  </div>
                  <div class="space-y-2">
                    <label class="font-label-md text-on-surface-variant" for="contact-email">Email *</label>
                    <input
                      class="w-full rounded-DEFAULT border border-outline-variant bg-surface-container-low px-4 py-3 text-body-md outline-none transition-all focus:border-primary focus:ring-1 focus:ring-primary"
                      id="contact-email"
                      name="email"
                      required
                      type="email"
                    />
                  </div>
                </div>
                <div class="space-y-2">
                  <label class="font-label-md text-on-surface-variant" for="contact-subject">Θέμα</label>
                  <input
                    class="w-full rounded-DEFAULT border border-outline-variant bg-surface-container-low px-4 py-3 text-body-md outline-none transition-all focus:border-primary focus:ring-1 focus:ring-primary"
                    id="contact-subject"
                    name="subject"
                    type="text"
                  />
                </div>
                <div class="space-y-2">
                  <label class="font-label-md text-on-surface-variant" for="contact-message">Μήνυμα *</label>
                  <textarea
                    class="w-full resize-none rounded-DEFAULT border border-outline-variant bg-surface-container-low px-4 py-3 text-body-md outline-none transition-all focus:border-primary focus:ring-1 focus:ring-primary"
                    id="contact-message"
                    name="message"
                    required
                    rows="5"
                  ></textarea>
                </div>
                <div class="pt-4 text-center">
                  <button
                    class="w-full rounded-full bg-primary py-4 font-label-lg text-lg text-on-primary shadow-sm transition-all duration-300 hover:translate-y-[-1px] hover:shadow-md active:scale-95"
                    type="submit"
                  >
                    Αποστολή μηνύματος
                  </button>
                  <p class="mt-4 font-body-sm text-body-sm text-on-surface-variant">{formSubmitNote}</p>
                </div>
              </form>
          </FluentFormEmbed>
        </div>
      </section>
    </div>
  </div>
</SiteLayout>
