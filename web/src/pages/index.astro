---
import SiteLayout from '../layouts/SiteLayout.astro';
import TrustPartnersSlider from '../components/TrustPartnersSlider.astro';
import { fetchCaseStudies, fetchPageFields, fetchPageSeoData, pageField, pageFieldLines } from '../lib/cms';
import { resolvePageLocale } from '../lib/i18n';

const locale = resolvePageLocale(Astro.currentLocale);
const fields = await fetchPageFields('home', locale);
const seoData = await fetchPageSeoData('home', locale);
const caseStudies = await fetchCaseStudies(4, locale);

const heroHighlight = pageField(fields, 'fti_home_hero_title_highlight', 'μεράκι');
const heroTitleRaw = pageField(fields, 'fti_home_hero_title', 'Ιστοσελίδες με μεράκι και τεχνική αρτιότητα');
const heroTitle = heroTitleRaw.includes(heroHighlight)
  ? heroTitleRaw.replace(heroHighlight, `<span class="text-primary">${heroHighlight}</span>`)
  : heroTitleRaw;
const heroDescription = pageField(
  fields,
  'fti_home_hero_description',
  'Σχεδιάζουμε και αναπτύσσουμε custom ιστοσελίδες για μικρομεσαίες επιχειρήσεις που θέλουν να ξεχωρίσουν στην ψηφιακή εποχή.',
);
const heroEyebrow = pageField(fields, 'fti_home_hero_eyebrow', 'Εξειδικευμένοι στην Ελλάδα');
const heroImage =
  pageField(fields, 'fti_home_hero_image') ||
  'https://lh3.googleusercontent.com/aida-public/AB6AXuBl8vg9URUb2UOq3oTy5M1Js7fM4eysXbQAVXEgSzd77tbqNFfwbE5qctnA20WA7FH20gcc9vszj5SusHGW9n08o09WUZAQzzHa1IHubdRDe0MLU6WBFtjKXXAViJWJXl383nBfqzJAs83I-yFLrRievgHMuIwK1Hph7SxBl6-zjqFoMHQvtsju2LRC60awxFViwzpONoWl0jdHfG6Mxr3if3uyRDPQUS6olvo1UXnymYaFF99tM0tViU9JzBC0K11jgrJCuXh_ayY';

const trustTitle = pageField(fields, 'fti_home_trust_title', 'Εμπιστεύονται την τεχνογνωσία μας');
const trustPartners = pageFieldLines(fields, 'fti_home_trust_partners');

const advantagesTitle = pageField(fields, 'fti_home_advantages_title', 'Γιατί Astro + WordPress;');
const advantagesDescription = pageField(
  fields,
  'fti_home_advantages_description',
  'Ο συνδυασμός της ταχύτητας του Astro με την ευκολία διαχείρισης του WordPress δημιουργεί το απόλυτο εργαλείο για την επιχείρησή σας.',
);
const advantages = [
  {
    icon: pageField(fields, 'fti_home_advantage_1_icon', 'bolt'),
    title: pageField(fields, 'fti_home_advantage_1_title', 'Αστραπιαία Ταχύτητα'),
    text: pageField(fields, 'fti_home_advantage_1_body', 'Οι ιστοσελίδες μας φορτώνουν σε λιγότερο από 1 δευτερόλεπτο, βελτιώνοντας το SEO και την εμπειρία του χρήστη.'),
  },
  {
    icon: pageField(fields, 'fti_home_advantage_2_icon', 'security'),
    title: pageField(fields, 'fti_home_advantage_2_title', 'Απόλυτη Ασφάλεια'),
    text: pageField(fields, 'fti_home_advantage_2_body', 'Με την αρχιτεκτονική Headless, η βάση δεδομένων σας παραμένει κρυφή και απρόσβλητη από εξωτερικές επιθέσεις.'),
  },
  {
    icon: pageField(fields, 'fti_home_advantage_3_icon', 'edit_note'),
    title: pageField(fields, 'fti_home_advantage_3_title', 'Εύκολη Διαχείριση'),
    text: pageField(fields, 'fti_home_advantage_3_body', 'Συνεχίστε να χρησιμοποιείτε το οικείο περιβάλλον του WordPress για να αλλάζετε κείμενα και εικόνες χωρίς τεχνικές γνώσεις.'),
  },
];

const portfolioTitle = pageField(fields, 'fti_home_portfolio_title', 'Πρόσφατα Έργα');
const portfolioDescription = pageField(fields, 'fti_home_portfolio_description', 'Δείτε πώς βοηθήσαμε άλλες επιχειρήσεις να αναπτυχθούν.');
const portfolioLinkLabel = pageField(fields, 'fti_home_portfolio_link_label', 'Δείτε όλο το Portfolio');
const portfolioLinkUrl = pageField(fields, 'fti_home_portfolio_link_url', '/portfolio/');

const processTitle = pageField(fields, 'fti_home_process_title', 'Από τη στρατηγική στην υλοποίηση');
const processDescription = pageField(
  fields,
  'fti_home_process_description',
  'Ακολουθούμε μια δομημένη διαδικασία που εξασφαλίζει ότι το αποτέλεσμα θα είναι ανώτερο των προσδοκιών σας.',
);
const processSteps = [
  { title: pageField(fields, 'fti_home_process_step_1_title', 'Στρατηγική & Έρευνα'), body: pageField(fields, 'fti_home_process_step_1_body', '') },
  { title: pageField(fields, 'fti_home_process_step_2_title', 'Σχεδιασμός UI/UX'), body: pageField(fields, 'fti_home_process_step_2_body', '') },
  { title: pageField(fields, 'fti_home_process_step_3_title', 'Υλοποίηση & Test'), body: pageField(fields, 'fti_home_process_step_3_body', '') },
];
const processImage = pageField(fields, 'fti_home_process_image');

const ctaTitle = pageField(fields, 'fti_home_cta_title', 'Είστε έτοιμοι για το επόμενο βήμα;');
const ctaDescription = pageField(
  fields,
  'fti_home_cta_description',
  'Ελάτε να συζητήσουμε τις ανάγκες σας και να βρούμε την καλύτερη λύση για την ψηφιακή σας παρουσία.',
);
const ctaButtonLabel = pageField(fields, 'fti_home_cta_button_label', 'Ξεκινήστε το έργο σας');
const ctaButtonUrl = pageField(fields, 'fti_home_cta_button_url', '/quote/');
const ctaNote = pageField(fields, 'fti_home_cta_note', 'Δωρεάν συμβουλευτική και προσφορά εντός 24 ωρών.');
const heroBadgeValue = pageField(fields, 'fti_home_hero_badge_value', '10+');
const heroBadgeLabel = pageField(fields, 'fti_home_hero_badge_label', 'Χρόνια Εμπειρίας\nστον Σχεδιασμό');

const fallbackProjects = [
  {
    title: 'Artisan Ceramics',
    subtitle: 'E-commerce Design & Development',
    image:
      'https://lh3.googleusercontent.com/aida-public/AB6AXuAqalq0w6c89kGS5P89AhvhoMzC7iSanVbiiMZDF9EecoTknaPw7AB-l0sW_Q5o1QmzRLlKtBckAkw58QDUpCSc4u2_3tF2DO5aS4sQ7zwIinzFsfIVwEl7OqIXYp1d3H4Ad8gWEG4NTbtd5bBuFu8F7RDl5DtDQvLByiW0V58FalRb8czrInvOJJaC-nwdDKffJ9OIjl2kANC2lzkZlLmcp7n3b5w8har2E4zcPnIMoechswz95Nh3AajSlSoUDzK15JGFbe7-Oeo',
    tags: ['ASTRO', 'STRIPE'],
  },
  {
    title: 'Arch Studio X',
    subtitle: 'Corporate Brand Identity & Web',
    image:
      'https://lh3.googleusercontent.com/aida-public/AB6AXuDAYXbonoPcYwCb_3s-bDbwnQ_iECv3MGGPfxzBKzX7YKp3JsmUWDf7g-iY5afe_eDL0tXCfkb1WshVleDQCwiyr2BBBq6CfcAEyZ6sS-fFC5RrGmy5bD1_Uv1-ZLRQHprF-0B2wXRJiDQ9BQY3x62J8RJxrRfUS_W2VWQDvPXb0QuHcfbDO7Tmu91RD0NXSQ9_CUknAz6NrcnsHvtzHwBEcddSbPntv_u4aidvxsuuw9KyKwEoJwFLr7oOn_6Qq6uxztl_DEpbVUA',
    tags: ['NEXT.JS', 'GSAP'],
  },
];

const displayProjects =
  caseStudies.length > 0
    ? caseStudies.map((item) => ({
        title: item.title,
        subtitle: item.excerpt || item.clientName,
        image: item.imageUrl || fallbackProjects[0].image,
        tags: item.techStack.length > 0 ? item.techStack : ['ASTRO', 'WORDPRESS'],
      }))
    : fallbackProjects;
---

<SiteLayout
  canonicalPath="/"
  description="Ιστοσελίδες με μεράκι και τεχνική αρτιότητα. Custom web design & Astro + WordPress headless development στην Ελλάδα."
  locale={locale}
  seoData={seoData}
  title="Αρχική"
>
  <section class="mx-auto max-w-container-max-width overflow-hidden px-margin-mobile py-section-gap-mobile md:px-margin-desktop md:py-section-gap-desktop">
    <div class="grid grid-cols-1 items-center gap-gutter lg:grid-cols-2">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-secondary-fixed px-4 py-2 font-label-lg text-label-lg text-on-secondary-fixed">
          <span class="material-symbols-outlined text-[18px]">verified</span>
          {heroEyebrow}
        </div>
        <h1 class="font-display-lg-mobile text-display-lg-mobile tracking-tight text-on-surface md:font-display-lg md:text-display-lg" set:html={heroTitle} />
        <p class="max-w-xl font-body-lg text-body-lg text-on-surface-variant">{heroDescription}</p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a
            class="rounded-full bg-primary-container px-8 py-4 font-label-lg text-label-lg text-on-primary shadow-lg transition-all hover:translate-y-[-2px]"
            href={pageField(fields, 'fti_home_hero_primary_cta_url', '/quote/')}
          >
            {pageField(fields, 'fti_home_hero_primary_cta_label', 'Ξεκινήστε το έργο σας')}
          </a>
          <a
            class="rounded-full border border-outline-variant px-8 py-4 font-label-lg text-label-lg text-on-surface transition-all hover:bg-surface-container"
            href={pageField(fields, 'fti_home_hero_secondary_cta_url', '/portfolio/')}
          >
            {pageField(fields, 'fti_home_hero_secondary_cta_label', 'Δείτε το Portfolio')}
          </a>
        </div>
      </div>
      <div class="relative mt-12 lg:mt-0">
        <div class="relative z-10 aspect-square overflow-hidden rounded-xl shadow-2xl">
          <img alt="" class="h-full w-full object-cover" loading="eager" src={heroImage} />
        </div>
        <div class="absolute -right-6 -top-6 -z-0 h-32 w-32 rounded-full bg-secondary-container opacity-20 blur-3xl"></div>
        <div class="absolute -bottom-6 -left-6 -z-0 h-48 w-48 rounded-full bg-primary-container opacity-10 blur-3xl"></div>
        <div class="absolute bottom-8 right-8 z-20 hidden rounded-lg border border-outline-variant/30 bg-surface-container-lowest p-6 shadow-xl md:block">
          <div class="flex items-center gap-4">
            <div class="text-4xl text-primary">{heroBadgeValue}</div>
            <div class="font-label-md text-sm text-on-surface-variant whitespace-pre-line">
              {heroBadgeLabel}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-outline-variant/20 bg-surface-container-low py-12">
    <div class="mx-auto max-w-container-max-width px-margin-mobile md:px-margin-desktop">
      <p class="mb-8 text-center font-label-lg text-label-lg uppercase tracking-widest text-outline">
        {trustTitle}
      </p>
      <TrustPartnersSlider partners={trustPartners} />
    </div>
  </section>

  <section class="mx-auto max-w-container-max-width px-margin-mobile py-section-gap-mobile md:px-margin-desktop md:py-section-gap-desktop">
    <div class="mb-16 text-center">
      <h2 class="mb-4 font-headline-lg-mobile text-headline-lg-mobile text-on-surface md:font-headline-lg md:text-headline-lg">
        {advantagesTitle}
      </h2>
      <p class="mx-auto max-w-2xl font-body-lg text-body-lg text-on-surface-variant">{advantagesDescription}</p>
    </div>
    <div class="grid grid-cols-1 gap-gutter md:grid-cols-3">
      {
        advantages.map((card) => (
          <div class="group rounded-lg border border-outline-variant/30 bg-surface-container-lowest p-8 shadow-sm transition-all hover:shadow-md">
            <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-primary-fixed transition-colors group-hover:bg-primary group-hover:text-on-primary">
              <span class="material-symbols-outlined text-3xl">{card.icon}</span>
            </div>
            <h3 class="mb-4 font-headline-sm text-headline-sm">{card.title}</h3>
            <p class="text-on-surface-variant">{card.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-surface-container-high px-margin-mobile py-section-gap-mobile md:px-margin-desktop md:py-section-gap-desktop">
    <div class="mx-auto max-w-container-max-width">
      <div class="mb-12 flex flex-col items-end justify-between gap-4 md:flex-row">
        <div>
          <h2 class="mb-2 font-headline-lg-mobile text-headline-lg-mobile text-on-surface md:font-headline-lg md:text-headline-lg">
            {portfolioTitle}
          </h2>
          <p class="font-body-lg text-body-lg text-on-surface-variant">{portfolioDescription}</p>
        </div>
        <a class="group flex items-center gap-2 font-label-lg text-label-lg text-primary" href={portfolioLinkUrl}>
          {portfolioLinkLabel}
          <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">arrow_forward</span>
        </a>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {
          displayProjects.map((project) => (
            <div class="group cursor-pointer">
              <div class="relative mb-6 aspect-video overflow-hidden rounded-lg">
                <img
                  alt=""
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  src={project.image}
                />
                <div class="absolute inset-0 bg-primary/20 opacity-0 transition-opacity group-hover:opacity-100"></div>
              </div>
              <div class="flex items-start justify-between">
                <div>
                  <h4 class="mb-1 font-headline-sm text-headline-sm">{project.title}</h4>
                  <p class="text-on-surface-variant">{project.subtitle}</p>
                </div>
                <div class="flex gap-2">
                  {project.tags.map((tag) => (
                    <span class="rounded-full border border-outline-variant/30 bg-surface px-3 py-1 font-label-md text-xs">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    processTitle || processDescription ? (
      <section class="mx-auto max-w-container-max-width px-margin-mobile py-section-gap-mobile md:px-margin-desktop md:py-section-gap-desktop">
        <div class="relative overflow-hidden rounded-lg bg-inverse-surface p-12 text-on-primary-container md:p-20">
          <div class="relative z-10 grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
            <div>
              <h2 class="mb-6 font-headline-lg-mobile text-headline-lg-mobile text-surface-container-lowest md:font-headline-lg md:text-headline-lg">
                {processTitle}
              </h2>
              <p class="mb-12 font-body-lg text-body-lg text-surface-variant">{processDescription}</p>
              <div class="space-y-8">
                {processSteps.map((step, index) => (
                  <div class="flex gap-6">
                    <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-primary-container text-on-primary">
                      {index + 1}
                    </div>
                    <div>
                      <h4 class="mb-2 font-headline-sm text-headline-sm text-surface-container-lowest">{step.title}</h4>
                      <p class="text-surface-variant">{step.body}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            {processImage ? (
              <div class="hidden lg:block">
                <img alt="" class="h-[500px] w-full rounded-lg object-cover shadow-2xl" loading="lazy" src={processImage} />
              </div>
            ) : null}
          </div>
        </div>
      </section>
    ) : null
  }

  <section class="mx-auto max-w-container-max-width px-margin-mobile py-section-gap-mobile text-center md:px-margin-desktop md:py-section-gap-desktop">
    <div class="mx-auto max-w-3xl space-y-8">
      <h2 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface md:font-headline-lg md:text-headline-lg">
        {ctaTitle}
      </h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant">{ctaDescription}</p>
      <div class="pt-8">
        <a
          class="inline-block rounded-full bg-secondary-container px-12 py-6 font-headline-sm text-headline-sm text-on-secondary-container shadow-2xl transition-all hover:scale-105"
          href={ctaButtonUrl}
        >
          {ctaButtonLabel}
        </a>
        <p class="mt-4 font-label-md text-label-md text-on-surface-variant">{ctaNote}</p>
      </div>
    </div>
  </section>
</SiteLayout>
