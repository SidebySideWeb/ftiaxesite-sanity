---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { PortableText } from 'astro-portabletext';
import { localeToWpmlCode, resolvePageLocale, type SiteLocale } from '../../../lib/i18n';
import { fetchAllWordPressPostsForStaticPaths } from '../../../lib/wordpress.ts';
import type { BlogPost } from '../../../types';

export async function getStaticPaths() {
  const locale = 'en' satisfies SiteLocale;
  const publishedBlogPosts = await fetchAllWordPressPostsForStaticPaths(localeToWpmlCode(locale));
  return publishedBlogPosts.map((blogPost) => ({
    params: { slug: blogPost.slug },
    props: { blogPost },
  }));
}

interface Props {
  readonly blogPost: BlogPost;
}

const { blogPost } = Astro.props;
const locale = resolvePageLocale(Astro.currentLocale);

const pageDescription =
  blogPost.excerptPlainText.length > 0 ? blogPost.excerptPlainText : locale === 'en' ? 'Article' : 'Άρθρο';

const canonicalPath = `/blog/${blogPost.slug}/`;
const dateLocale = locale === 'en' ? 'en' : 'el';
---

<SiteLayout
  canonicalPath={canonicalPath}
  description={pageDescription}
  locale={locale}
  ogImageUrl={blogPost.featuredImageUrl}
  ogType="article"
  seoData={blogPost.seoData}
  title={blogPost.title}
>
  <article class="mx-auto max-w-3xl px-margin-mobile py-section-gap-mobile md:px-margin-desktop md:py-section-gap-desktop">
    <header class="border-b border-outline-variant/30 pb-8">
      <p class="font-label-md text-on-surface-variant">
        {
          new Intl.DateTimeFormat(dateLocale, {
            year: 'numeric',
            month: 'long',
            day: '2-digit',
          }).format(new Date(blogPost.publishedAt))
        }
      </p>
      <h1 class="mt-3 text-balance font-headline-lg text-headline-lg text-on-surface">
        {blogPost.title}
      </h1>
    </header>
    {
      blogPost.featuredImageUrl ? (
        <div class="mt-8 overflow-hidden rounded-lg border border-outline-variant/30 bg-surface-container">
          <img
            alt={blogPost.featuredImageAlt ?? blogPost.title}
            class="h-auto w-full object-cover"
            height={675}
            loading="eager"
            src={blogPost.featuredImageUrl}
            width={1200}
          />
        </div>
      ) : null
    }
    <div class="prose prose-neutral mt-10 max-w-none">
      {Array.isArray(blogPost.body) ? <PortableText value={blogPost.body} /> : null}
    </div>
  </article>
</SiteLayout>
