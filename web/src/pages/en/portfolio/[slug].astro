---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import CaseStudyDetail from '../../../components/CaseStudyDetail.astro';
import ServiceSchema from '../../../components/schema/ServiceSchema.astro';
import { fetchCaseStudyBySlug, fetchCaseStudySlugs } from '../../../lib/cms';
import { resolvePageLocale } from '../../../lib/i18n';

export async function getStaticPaths() {
  const slugs = await fetchCaseStudySlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const locale = resolvePageLocale(Astro.currentLocale);
const slug = Astro.params.slug ?? '';
const caseStudy = await fetchCaseStudyBySlug(slug, locale);

if (!caseStudy) {
  return Astro.redirect('/en/portfolio/');
}

const pageDescription =
  caseStudy.summary || 'Case study';

const serviceType = caseStudy.categoryBadge || caseStudy.title;
const audienceType = caseStudy.categoryBadge || caseStudy.title;
---

<SiteLayout
  canonicalPath={`/portfolio/${caseStudy.slug}/`}
  description={pageDescription}
  locale={locale}
  ogImageUrl={caseStudy.imageUrl}
  ogType="article"
  seoData={caseStudy.seoData}
  title={caseStudy.title}
>
  <ServiceSchema
    slot="schema"
    audienceType={audienceType}
    description={caseStudy.summary}
    serviceType={serviceType}
  />
  <CaseStudyDetail caseStudy={caseStudy} locale={locale} />
</SiteLayout>
