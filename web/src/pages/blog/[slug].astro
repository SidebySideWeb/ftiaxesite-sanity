---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import {PortableText} from 'astro-portabletext'
import {fetchPostBySlug, fetchServicePackages, fetchSiteSettings} from '../../lib/sanity'
import {DEFAULT_LOCALE, localizeHref, t, type Locale} from '../../lib/locale'

export const prerender = false

const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
const slug = Astro.params.slug ?? ''
const [settings, packages, post] = await Promise.all([
  fetchSiteSettings(),
  fetchServicePackages(),
  fetchPostBySlug(slug),
])

if (!post) {
  return Astro.redirect(localizeHref('/404/', locale))
}

const body = (locale === 'en' ? post.body?.en : post.body?.el) ?? post.body?.el ?? post.body?.en ?? []
const seoTitle = t(post.seoTitle, locale) || t(post.title, locale)
const seoDescription = t(post.seoDescription, locale) || t(post.excerpt, locale)
---

<BaseLayout title={`${seoTitle} | ftiaxesite.gr`} description={seoDescription} settings={settings}>
  <Nav settings={settings} />
  <main class="wrap block">
    <article class="prose reveal">
      <h1>{t(post.title, locale)}</h1>
      {post.excerpt ? <p>{t(post.excerpt, locale)}</p> : null}
      <PortableText value={body} />
    </article>
  </main>
  <Footer settings={settings} packages={packages} />
</BaseLayout>
