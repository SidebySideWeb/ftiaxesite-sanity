---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import {PortableText} from 'astro-portabletext'
import {fetchPostBySlug, fetchServicePackages, fetchSiteSettings} from '../../lib/sanity'
import {t} from '../../lib/locale'

export const prerender = false

const slug = Astro.params.slug ?? ''
const [settings, packages, post] = await Promise.all([
  fetchSiteSettings(),
  fetchServicePackages(),
  fetchPostBySlug(slug),
])

if (!post) {
  return Astro.redirect('/404/')
}

const body = post.body?.el ?? post.body?.en ?? []
const seoTitle = t(post.seoTitle, 'el') || t(post.title, 'el')
const seoDescription = t(post.seoDescription, 'el') || t(post.excerpt, 'el')
---

<BaseLayout title={`${seoTitle} | ftiaxesite.gr`} description={seoDescription} settings={settings}>
  <Nav settings={settings} />
  <main class="wrap block">
    <article class="prose reveal">
      <h1>{t(post.title, 'el')}</h1>
      {post.excerpt ? <p>{t(post.excerpt, 'el')}</p> : null}
      <PortableText value={body} />
    </article>
  </main>
  <Footer settings={settings} packages={packages} />
</BaseLayout>
