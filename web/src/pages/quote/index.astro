---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import QuoteForm from '../../components/QuoteForm.astro'
import {fetchHomePage, fetchServicePackages, fetchSiteSettings} from '../../lib/sanity'
import {t} from '../../lib/locale'

const [settings, home, packages] = await Promise.all([
  fetchSiteSettings(),
  fetchHomePage(),
  fetchServicePackages(),
])
const copy = home?.quoteForm
---

<BaseLayout
  title={t(copy?.title, 'el') ? `${t(copy?.title, 'el')} | ftiaxesite.gr` : undefined}
  description={t(copy?.intro, 'el') || undefined}
  settings={settings}
>
  <Nav settings={settings} />
  <main class="wrap" style="padding:48px 0 88px">
    <QuoteForm home={home} packages={packages} settings={settings} formId="quotePageForm" showHeader={true} />
  </main>
  <Footer settings={settings} packages={packages} />
</BaseLayout>
