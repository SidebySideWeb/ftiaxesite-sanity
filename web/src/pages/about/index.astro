---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { fetchPageFields, fetchPageSeoData, pageField } from '../../lib/cms';
import { resolvePageLocale } from '../../lib/i18n';

const locale = resolvePageLocale(Astro.currentLocale);
const fields = await fetchPageFields('about', locale);
const seoData = await fetchPageSeoData('about', locale);

const heroEyebrow = pageField(fields, 'fti_about_hero_eyebrow', 'Η ιστορία μας');
const heroTitle = pageField(fields, 'fti_about_hero_title', 'Φτιάχνουμε ιστοσελίδες με μεράκι και τεχνική αρτιότητα');
const heroDescription = pageField(
  fields,
  'fti_about_hero_description',
  'Είμαστε μια ομάδα που συνδυάζει σχεδιασμό, ανάπτυξη και στρατηγική για να δημιουργεί ψηφιακές εμπειρίες που βοηθούν τις ελληνικές επιχειρήσεις να ξεχωρίσουν.',
);
const heroImage = pageField(fields, 'fti_about_hero_image');

const philosophyTitle = pageField(
  fields,
  'fti_about_philosophy_title',
  'Πιστεύουμε ότι μια καλή ιστοσελίδα είναι επένδυση, όχι έξοδο.',
);

const story1 = {
  title: pageField(fields, 'fti_about_story_1_title', 'Από την ιδέα στην υλοποίηση'),
  body: pageField(
    fields,
    'fti_about_story_1_body',
    'Ξεκινάμε κάθε project κατανοώντας την επιχείρηση, το κοινό και τους στόχους. Δεν κάνουμε templates — σχεδιάζουμε λύσεις προσαρμοσμένες στις ανάγκες σας, με καθαρό κώδικα και εστίαση στην ταχύτητα.',
  ),
  bullet1: pageField(fields, 'fti_about_story_1_bullet_1', 'Στρατηγική & UX πριν από τον κώδικα'),
  bullet2: pageField(fields, 'fti_about_story_1_bullet_2', 'Astro frontend για μέγιστη απόδοση'),
  image: pageField(fields, 'fti_about_story_1_image'),
};

const story2 = {
  title: pageField(fields, 'fti_about_story_2_title', 'WordPress όταν χρειάζεται, headless όταν μετράει'),
  body: pageField(
    fields,
    'fti_about_story_2_body',
    'Χρησιμοποιούμε WordPress ως CMS όταν θέλετε να διαχειρίζεστε μόνοι σας το περιεχόμενο — αλλά το frontend μένει γρήγορο και ασφαλές χάρη στην headless αρχιτεκτονική.',
  ),
  ctaLabel: pageField(fields, 'fti_about_story_2_cta_label', 'Δες τις υπηρεσίες μας'),
  ctaUrl: pageField(fields, 'fti_about_story_2_cta_url', '/services/'),
  image: pageField(fields, 'fti_about_story_2_image'),
};

const valuesTitle = pageField(fields, 'fti_about_values_title', 'Τι μας ξεχωρίζει');
const defaultValues = [
  { title: 'Τεχνική αρτιότητα', body: 'Καθαρός κώδικας, γρήγορα sites και λύσεις που κρατούν στο χρόνο.' },
  { title: 'Διαφάνεια', body: 'Σαφείς προσφορές, ρεαλιστικά χρονοδιαγράμματα και άμεση επικοινωνία.' },
  { title: 'Εστίαση στο αποτέλεσμα', body: 'Στόχος μας δεν είναι απλά μια όμορφη σελίδα — είναι η επιτυχία της επιχείρησής σας online.' },
];
const values = [1, 2, 3].map((index) => ({
  title: pageField(fields, `fti_about_value_${index}_title`, defaultValues[index - 1].title),
  body: pageField(fields, `fti_about_value_${index}_body`, defaultValues[index - 1].body),
}));

const ctaTitle = pageField(fields, 'fti_about_cta_title', 'Ας μιλήσουμε για το project σου');
const ctaDescription = pageField(
  fields,
  'fti_about_cta_description',
  'Πες μας τι χρειάζεσαι — θα σου απαντήσουμε με μια προσαρμοσμένη πρόταση εντός 24 ωρών.',
);
const ctaButtonLabel = pageField(fields, 'fti_about_cta_button_label', 'Ζήτα Προσφορά');
const ctaButtonUrl = pageField(fields, 'fti_about_cta_button_url', '/quote/');
---

<SiteLayout
  canonicalPath="/about/"
  description="Μάθε περισσότερα για την ομάδα του ftiaxesite.gr — custom ιστοσελίδες με Astro και WordPress για επιχειρήσεις στην Ελλάδα."
  locale={locale}
  seoData={seoData}
  title="Σχετικά με εμάς"
>
  <section class="mx-auto grid max-w-container-max-width grid-cols-1 items-center gap-gutter px-margin-mobile py-section-gap-mobile md:grid-cols-12 md:px-margin-desktop md:py-section-gap-desktop">
    <div class="md:col-span-5">
      {
        heroEyebrow ? (
          <span class="mb-6 inline-block font-label-lg text-label-lg uppercase tracking-widest text-primary">{heroEyebrow}</span>
        ) : null
      }
      <h1 class="mb-8 font-headline-lg text-headline-lg-mobile text-on-surface md:text-headline-lg">{heroTitle}</h1>
      <p class="max-w-md font-body-lg text-body-lg text-on-surface-variant">{heroDescription}</p>
    </div>
    {
      heroImage ? (
        <div class="md:col-span-7">
          <div class="relative h-[320px] overflow-hidden rounded-lg shadow-sm md:h-[520px]">
            <img alt="" class="h-full w-full object-cover" loading="eager" src={heroImage} />
          </div>
        </div>
      ) : null
    }
  </section>

  {
    philosophyTitle ? (
      <section class="bg-surface-container-low py-16 md:py-24">
        <div class="mx-auto max-w-container-max-width px-margin-mobile md:px-margin-desktop">
          <h2 class="max-w-4xl font-headline-md text-headline-md text-on-surface">{philosophyTitle}</h2>
        </div>
      </section>
    ) : null
  }

  <section class="mx-auto max-w-container-max-width space-y-24 px-margin-mobile py-section-gap-mobile md:px-margin-desktop md:py-section-gap-desktop">
    {
      story1.title || story1.body ? (
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
          <div class="space-y-6">
            <h2 class="font-headline-md text-headline-md text-on-surface">{story1.title}</h2>
            <p class="font-body-lg text-body-lg text-on-surface-variant">{story1.body}</p>
            <ul class="space-y-3 font-body-md text-body-md text-on-surface">
              {story1.bullet1 ? <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary">check_circle</span>{story1.bullet1}</li> : null}
              {story1.bullet2 ? <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary">check_circle</span>{story1.bullet2}</li> : null}
            </ul>
          </div>
          {
            story1.image ? (
              <div class="overflow-hidden rounded-lg shadow-sm">
                <img alt="" class="h-[360px] w-full object-cover md:h-[420px]" loading="lazy" src={story1.image} />
              </div>
            ) : null
          }
        </div>
      ) : null
    }

    {
      story2.title || story2.body ? (
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
          {
            story2.image ? (
              <div class="order-2 overflow-hidden rounded-lg shadow-sm lg:order-1">
                <img alt="" class="h-[360px] w-full object-cover md:h-[420px]" loading="lazy" src={story2.image} />
              </div>
            ) : null
          }
          <div class="order-1 space-y-6 lg:order-2">
            <h2 class="font-headline-md text-headline-md text-on-surface">{story2.title}</h2>
            <p class="font-body-lg text-body-lg text-on-surface-variant">{story2.body}</p>
            {
              story2.ctaLabel ? (
                <a
                  class="inline-flex items-center gap-2 font-label-lg text-label-lg text-primary transition-opacity hover:opacity-80"
                  href={story2.ctaUrl}
                >
                  {story2.ctaLabel}
                  <span class="material-symbols-outlined text-base">arrow_forward</span>
                </a>
              ) : null
            }
          </div>
        </div>
      ) : null
    }
  </section>

  {
    values.length > 0 ? (
      <section class="bg-surface-container px-margin-mobile py-section-gap-mobile md:px-margin-desktop md:py-section-gap-desktop">
        <div class="mx-auto max-w-container-max-width">
          <h2 class="mb-12 text-center font-headline-lg text-headline-lg-mobile text-on-surface md:text-headline-lg">{valuesTitle}</h2>
          <div class="grid gap-8 md:grid-cols-3">
            {
              values.map((value) => (
                <div class="rounded-lg border border-outline-variant/30 bg-surface-container-lowest p-8">
                  <h3 class="mb-4 font-headline-sm text-headline-sm text-on-surface">{value.title}</h3>
                  <p class="font-body-md text-body-md text-on-surface-variant">{value.body}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>
    ) : null
  }

  <section class="mx-auto max-w-container-max-width px-margin-mobile py-section-gap-mobile text-center md:px-margin-desktop md:py-section-gap-desktop">
    <div class="mx-auto max-w-3xl space-y-8">
      <h2 class="font-headline-lg text-headline-lg-mobile text-on-surface md:text-headline-lg">{ctaTitle}</h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant">{ctaDescription}</p>
      <a
        class="inline-block rounded-full bg-primary-container px-12 py-5 font-label-lg text-label-lg text-on-primary shadow-lg transition-all hover:scale-105"
        href={ctaButtonUrl}
      >
        {ctaButtonLabel}
      </a>
    </div>
  </section>
</SiteLayout>
