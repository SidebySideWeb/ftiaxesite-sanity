---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import ProjectCard from '../../components/ProjectCard.astro'
import Localized from '../../components/Localized.astro'
import {fetchHomePage, fetchProjects, fetchServicePackages, fetchSiteSettings} from '../../lib/sanity'

const [settings, home, projects, packages] = await Promise.all([
  fetchSiteSettings(),
  fetchHomePage(),
  fetchProjects(),
  fetchServicePackages(),
])
---

<BaseLayout title={home?.workHeading?.el ? `${home.workHeading.el} | ftiaxesite.gr` : undefined} settings={settings}>
  <Nav settings={settings} />
  <main class="wrap block">
    <div class="page-hero reveal">
      <Localized value={home?.workEyebrow} tag="span" class="eyebrow" />
      <Localized value={home?.workHeading} tag="h1" />
      <Localized value={home?.workIntro} tag="p" />
    </div>
    <div class="work-grid card-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </main>
  <Footer settings={settings} packages={packages} />
</BaseLayout>
