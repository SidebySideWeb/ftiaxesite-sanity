---
import type {OrganizationSchemaData} from '../lib/cms'

interface Props {
  readonly organization: OrganizationSchemaData
}

const {organization} = Astro.props

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: organization.name,
  url: organization.url,
  ...(organization.logoUrl ? {logo: organization.logoUrl} : {}),
  ...(organization.email || organization.telephone
    ? {
        contactPoint: {
          '@type': 'ContactPoint',
          contactType: 'customer service',
          ...(organization.email ? {email: organization.email} : {}),
          ...(organization.telephone ? {telephone: organization.telephone} : {}),
        },
      }
    : {}),
  ...(organization.sameAs.length > 0 ? {sameAs: organization.sameAs} : {}),
}
---

<script is:inline set:html={JSON.stringify(schema)} type="application/ld+json" />
