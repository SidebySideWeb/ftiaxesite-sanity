---
interface Props {
  readonly partners: readonly string[];
  readonly durationSeconds?: number;
}

const { partners, durationSeconds = 32 } = Astro.props;

const items =
  partners.length > 0
    ? partners
    : ['ALPHA TECH', 'RETAIL GREECE', 'MED LOGISTICS', 'CONSTRUCTION SA'];
---

<div
  class="trust-partners-ticker opacity-80 transition-opacity hover:opacity-100"
  aria-label="Trusted partners"
  style={`--trust-ticker-duration: ${durationSeconds}s`}
>
  <div class="trust-partners-ticker__viewport">
    <div class="trust-partners-ticker__track">
      {
        [0, 1].map((copy) => (
          <ul
            class="trust-partners-ticker__group"
            aria-hidden={copy === 1 ? true : undefined}
          >
            {
              items.map((partner) => (
                <li class="trust-partners-ticker__item">
                  <span class="trust-partners-ticker__label">{partner}</span>
                </li>
              ))
            }
          </ul>
        ))
      }
    </div>
  </div>
</div>

<style>
  .trust-partners-ticker__viewport {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .trust-partners-ticker__track {
    display: flex;
    width: max-content;
    animation: trust-partners-scroll var(--trust-ticker-duration, 32s) linear infinite;
  }

  .trust-partners-ticker:hover .trust-partners-ticker__track {
    animation-play-state: paused;
  }

  .trust-partners-ticker__group {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 2rem;
    padding-right: 2rem;
    list-style: none;
    margin: 0;
  }

  @media (min-width: 768px) {
    .trust-partners-ticker__group {
      gap: 3rem;
      padding-right: 3rem;
    }
  }

  .trust-partners-ticker__item {
    flex-shrink: 0;
  }

  .trust-partners-ticker__label {
    display: inline-block;
    white-space: nowrap;
    border-radius: 0.375rem;
    background-color: #f4f4f2;
    padding: 0.5rem 1.5rem;
    font-family: 'Noto Serif', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: #1a1a1a;
  }

  @media (min-width: 768px) {
    .trust-partners-ticker__label {
      padding: 0.625rem 2rem;
      font-size: 1.125rem;
    }
  }

  @keyframes trust-partners-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-partners-ticker__viewport {
      mask-image: none;
      -webkit-mask-image: none;
    }

    .trust-partners-ticker__track {
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      animation: none;
      gap: 1rem;
    }

    .trust-partners-ticker__group {
      flex-wrap: wrap;
      justify-content: center;
      padding-right: 0;
    }

    .trust-partners-ticker__group[aria-hidden='true'] {
      display: none;
    }
  }
</style>
