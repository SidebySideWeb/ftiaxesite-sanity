---
import {
  resolveImageDelivery,
  resolvePresetDelivery,
  type ImagePreset,
} from '../lib/responsive-image'

interface Props {
  readonly src: string
  readonly alt?: string
  readonly class?: string
  readonly loading?: 'lazy' | 'eager'
  readonly preset?: ImagePreset
  readonly sizes?: string
  readonly widths?: readonly number[]
}

const {src, alt = '', class: className, loading = 'lazy', preset, sizes, widths} = Astro.props

const delivery =
  preset != null
    ? resolvePresetDelivery(src, preset)
    : sizes && widths
      ? resolveImageDelivery(src, {sizes, widths})
      : resolveImageDelivery(src, {sizes: '100vw', widths: [640]})
---

{
  delivery?.kind === 'picture' ? (
    <picture>
      {delivery.sources.map((source) => (
        <source sizes={delivery.sizes} srcset={source.srcSet} type={source.type} />
      ))}
      <img alt={alt} class={className} decoding="async" loading={loading} src={delivery.src} />
    </picture>
  ) : delivery?.kind === 'img' ? (
    <img
      alt={alt}
      class={className}
      decoding="async"
      loading={loading}
      sizes={delivery.sizes}
      src={delivery.src}
      srcset={delivery.srcSet}
    />
  ) : delivery?.kind === 'plain' ? (
    <img alt={alt} class={className} decoding="async" loading={loading} src={delivery.src} />
  ) : null
}
