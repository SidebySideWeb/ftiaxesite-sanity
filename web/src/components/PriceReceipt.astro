---
import Localized from './Localized.astro'
import {deliveryLabel, formatPrice, DEFAULT_LOCALE, t, type Locale, type LocalizedString} from '../lib/locale'
import type {ServicePackageDoc} from '../lib/types'

interface Props {
  packages: readonly ServicePackageDoc[]
  badge?: LocalizedString | null
}

const {packages, badge} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
---

<div class="mock">
  <div class="mock-bar"><i></i><i></i><i></i><span class="mock-url">ftiaxesite.gr</span></div>
  <div class="mock-body">
    {
      packages.map((pkg) => (
        <div class="receipt-row">
          <span class="svc">
            <span>{t(pkg.title, locale)}</span>
            <span class="time">{deliveryLabel(pkg.deliveryDaysMin, pkg.deliveryDaysMax, locale)}</span>
          </span>
          <span class="price">{pkg.price != null ? formatPrice(pkg.price, locale) : ''}</span>
        </div>
      ))
    }
    {badge ? <Localized value={badge} tag="span" class="receipt-tag" /> : null}
  </div>
</div>
