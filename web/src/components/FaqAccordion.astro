---
import Localized from './Localized.astro'
import type {FaqItemDoc, HomePageDoc} from '../lib/types'
import {DEFAULT_LOCALE, t, type Locale} from '../lib/locale'

interface Props {
  home: HomePageDoc | null
  faqs: readonly FaqItemDoc[]
}

const {home, faqs} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
---

<section id="faq" class="block">
  <div class="wrap">
    <div class="sec-head reveal" style="margin-left:auto;margin-right:auto;text-align:center">
      <Localized value={home?.faqEyebrow} tag="span" class="eyebrow" />
      <Localized value={home?.faqHeading} tag="h2" />
      {home?.faqIntro ? <Localized value={home.faqIntro} tag="p" /> : null}
    </div>
    <div class="faq-list reveal">
      {
        faqs.map((item) => (
          <details class="faq-item">
            <summary>
              <span>{t(item.question, locale)}</span>
              <span class="sign">+</span>
            </summary>
            <p class="answer">{t(item.answer, locale)}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
