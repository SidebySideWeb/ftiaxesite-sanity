---
import Localized from './Localized.astro'
import type {HomePageDoc, ProcessStepDoc} from '../lib/types'
import {DEFAULT_LOCALE, t, type Locale} from '../lib/locale'

interface Props {
  home: HomePageDoc | null
  steps: readonly ProcessStepDoc[]
}

const {home, steps} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
---

<section id="process" class="block">
  <div class="wrap">
    <div class="sec-head reveal">
      <Localized value={home?.processEyebrow} tag="span" class="eyebrow" />
      <Localized value={home?.processHeading} tag="h2" />
      {home?.processIntro ? <Localized value={home.processIntro} tag="p" /> : null}
    </div>
    <div class="steps">
      {
        steps.map((step) => (
          <div class="step reveal">
            <span class="n"></span>
            <h3>{t(step.title, locale)}</h3>
            <p>{t(step.description, locale)}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
