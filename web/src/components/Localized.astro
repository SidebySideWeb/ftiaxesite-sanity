---
import {localeAttrs, t, type LocalizedString} from '../lib/locale'

interface Props {
  value?: LocalizedString | null
  tag?: keyof HTMLElementTagNameMap
  class?: string
}

const {value, tag: Tag = 'span', class: className} = Astro.props
---

<Tag class={className} {...localeAttrs(value)} set:html={t(value, 'el')} />
