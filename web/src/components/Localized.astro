---
import {t, type LocalizedString, type Locale, DEFAULT_LOCALE} from '../lib/locale'

interface Props {
  value?: LocalizedString | null
  tag?: keyof HTMLElementTagNameMap
  class?: string
}

const {value, tag: Tag = 'span', class: className} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
---

<Tag class={className} set:html={t(value, locale)} />
