---
const CAL_BOOKING_URL = 'https://cal.com/dimitris-geronikolos-z3h6en/15min'

interface Props {
  readonly label?: string
  readonly class?: string
}

const {
  label = 'Κλείσε ένα 15-λεπτο call →',
  class: className = 'inline-block w-full rounded-full bg-primary px-8 py-4 font-label-lg text-lg text-on-primary shadow-sm transition-all duration-300 hover:translate-y-[-1px] hover:shadow-md active:scale-95 sm:w-auto',
} = Astro.props
---

<a class={className} href={CAL_BOOKING_URL} rel="noopener noreferrer" target="_blank">
  {label}
</a>
