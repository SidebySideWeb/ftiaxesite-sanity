---
import {deliveryLabel, formatPrice, DEFAULT_LOCALE, t, type Locale} from '../lib/locale'
import type {HomePageDoc, ServicePackageDoc} from '../lib/types'

interface Props {
  pkg: ServicePackageDoc
  home: HomePageDoc | null
}

const {pkg, home} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
const slug = pkg.slug?.current ?? ''
const featured = Boolean(pkg.featured)
const btnClass = featured ? 'btn btn-primary' : 'btn btn-ghost'
---

<div class={`card pcard reveal${featured ? ' feat' : ''}`}>
  {
    featured && home?.popularBadgeLabel ? (
      <span class="badge">{t(home.popularBadgeLabel, locale)}</span>
    ) : (
      <span class="badge ghost" aria-hidden="true">.</span>
    )
  }
  <h3>{t(pkg.title, locale)}</h3>
  <p class="desc">{t(pkg.description, locale)}</p>
  <div class="amount">{pkg.price != null ? formatPrice(pkg.price, locale) : ''}</div>
  <div class="delivery">{deliveryLabel(pkg.deliveryDaysMin, pkg.deliveryDaysMax, locale)}</div>
  <ul>
    {(pkg.features ?? []).map((feature) => <li>{t(feature, locale)}</li>)}
  </ul>
  {
    home?.packageCtaLabel ? (
      <button type="button" class={btnClass} data-open="quoteModal" data-package={slug}>
        {t(home.packageCtaLabel, locale)}
      </button>
    ) : null
  }
</div>
