---
import Localized from './Localized.astro'
import {deliveryLabel, formatPrice, localeAttrs, t} from '../lib/locale'
import type {HomePageDoc, ServicePackageDoc} from '../lib/types'

interface Props {
  pkg: ServicePackageDoc
  home: HomePageDoc | null
}

const {pkg, home} = Astro.props
const slug = pkg.slug?.current ?? ''
const featured = Boolean(pkg.featured)
const btnClass = featured ? 'btn btn-primary' : 'btn btn-ghost'
---

<div class={`card pcard reveal${featured ? ' feat' : ''}`}>
  {
    featured && home?.popularBadgeLabel ? (
      <span class="badge" {...localeAttrs(home.popularBadgeLabel)}>{t(home.popularBadgeLabel, 'el')}</span>
    ) : (
      <span class="badge ghost" aria-hidden="true">.</span>
    )
  }
  <h3 {...localeAttrs(pkg.title)}>{t(pkg.title, 'el')}</h3>
  <p class="desc" {...localeAttrs(pkg.description)}>{t(pkg.description, 'el')}</p>
  <div class="amount">{pkg.price != null ? formatPrice(pkg.price, 'el') : ''}</div>
  <div
    class="delivery"
    {...localeAttrs({
      el: deliveryLabel(pkg.deliveryDaysMin, pkg.deliveryDaysMax, 'el'),
      en: deliveryLabel(pkg.deliveryDaysMin, pkg.deliveryDaysMax, 'en'),
    })}
  >
    {deliveryLabel(pkg.deliveryDaysMin, pkg.deliveryDaysMax, 'el')}
  </div>
  <ul>
    {
      (pkg.features ?? []).map((feature) => (
        <li {...localeAttrs(feature)}>{t(feature, 'el')}</li>
      ))
    }
  </ul>
  {
    home?.packageCtaLabel ? (
      <button
        type="button"
        class={btnClass}
        data-open="quoteModal"
        data-package={slug}
        {...localeAttrs(home.packageCtaLabel)}
      >
        {t(home.packageCtaLabel, 'el')}
      </button>
    ) : null
  }
</div>
