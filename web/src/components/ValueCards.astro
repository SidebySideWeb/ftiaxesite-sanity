---
import type {ValuePropDoc} from '../lib/types'
import {DEFAULT_LOCALE, t, type Locale} from '../lib/locale'

interface Props {
  items: readonly ValuePropDoc[]
}

const {items} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
---

<section class="block" style="padding-top:20px;padding-bottom:8px">
  <div class="wrap">
    <div class="values-grid card-grid">
      {
        items.map((item, index) => (
          <div class="card vcard reveal">
            <span class="vnum">{String(index + 1).padStart(2, '0')}</span>
            <h2>{t(item.title, locale)}</h2>
            <p>{t(item.description, locale)}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
