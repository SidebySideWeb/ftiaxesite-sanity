---
import type { MenuItem, SiteSettings } from '../lib/cms';

interface Props {
  readonly menus: readonly MenuItem[];
  readonly settings: SiteSettings;
  readonly currentPath: string;
}

const { menus, settings, currentPath } = Astro.props;
const mobileMenuId = 'site-mobile-nav';
---

<nav
  class="fixed top-0 z-50 w-full border-b border-outline-variant/30 bg-surface/80 shadow-sm transition-all duration-300 ease-in-out glass-nav"
  data-site-nav
>
  <div class="mx-auto flex h-20 max-w-container-max-width items-center justify-between px-margin-mobile md:px-margin-desktop">
    <a class="font-headline-sm text-headline-sm text-primary" href={settings.headerLogoUrl}>
      {settings.headerLogoText}
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {
        menus.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              class:list={[
                'font-label-lg text-label-lg transition-opacity hover:opacity-80',
                isActive ? 'border-b-2 border-primary text-primary' : 'text-on-surface-variant hover:text-primary',
              ]}
              href={item.href}
            >
              {item.title}
            </a>
          );
        })
      }
    </div>

    <div class="flex items-center gap-3 sm:gap-4">
      <a
        class="hidden rounded-full bg-primary-container px-6 py-3 font-label-lg text-label-lg text-on-primary shadow-md transition-all hover:opacity-90 sm:block"
        href={settings.headerCtaUrl}
      >
        {settings.headerCtaLabel}
      </a>

      <button
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-outline-variant/40 text-on-surface-variant transition-colors hover:bg-surface-container md:hidden"
        aria-controls={mobileMenuId}
        aria-expanded="false"
        aria-label="Άνοιγμα κύριου μενού"
        data-mobile-nav-toggle
      >
        <span class="material-symbols-outlined text-[26px]" data-mobile-nav-icon-open>menu</span>
        <span class="material-symbols-outlined hidden text-[26px]" data-mobile-nav-icon-close>close</span>
      </button>
    </div>
  </div>

  <div
    class="hidden border-t border-outline-variant/20 bg-surface/95 backdrop-blur-md md:hidden"
    id={mobileMenuId}
    data-mobile-nav-panel
  >
    <div class="mx-auto max-w-container-max-width px-margin-mobile py-4">
      <ul class="flex flex-col gap-1">
        {
          menus.map((item) => {
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <li>
                <a
                  class:list={[
                    'block rounded-md px-3 py-3 font-label-lg text-label-lg transition-colors',
                    isActive
                      ? 'bg-primary-fixed text-primary'
                      : 'text-on-surface-variant hover:bg-surface-container hover:text-primary',
                  ]}
                  href={item.href}
                  data-mobile-nav-link
                >
                  {item.title}
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    var nav = document.querySelector('[data-site-nav]');
    var toggle = document.querySelector('[data-mobile-nav-toggle]');
    var panel = document.querySelector('[data-mobile-nav-panel]');
    var iconOpen = document.querySelector('[data-mobile-nav-icon-open]');
    var iconClose = document.querySelector('[data-mobile-nav-icon-close]');
    var mobileLinks = document.querySelectorAll('[data-mobile-nav-link]');

    function setMobileNavOpen(open) {
      if (!toggle || !panel || !iconOpen || !iconClose) return;

      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Κλείσιμο κύριου μενού' : 'Άνοιγμα κύριου μενού');
      panel.classList.toggle('hidden', !open);
      iconOpen.classList.toggle('hidden', open);
      iconClose.classList.toggle('hidden', !open);
      document.body.classList.toggle('overflow-hidden', open);
    }

    toggle?.addEventListener('click', function () {
      var isOpen = toggle.getAttribute('aria-expanded') === 'true';
      setMobileNavOpen(!isOpen);
    });

    mobileLinks.forEach(function (link) {
      link.addEventListener('click', function () {
        setMobileNavOpen(false);
      });
    });

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') {
        setMobileNavOpen(false);
      }
    });

    window.addEventListener('resize', function () {
      if (window.matchMedia('(min-width: 768px)').matches) {
        setMobileNavOpen(false);
      }
    });

    if (nav) {
      var scrollTicking = false;
      window.addEventListener(
        'scroll',
        function () {
          if (scrollTicking) return;
          scrollTicking = true;
          requestAnimationFrame(function () {
            if (window.scrollY > 50) {
              nav.classList.add('h-16', 'shadow-md');
              nav.classList.remove('h-20', 'shadow-sm');
            } else {
              nav.classList.remove('h-16', 'shadow-md');
              nav.classList.add('h-20', 'shadow-sm');
            }
            scrollTicking = false;
          });
        },
        { passive: true },
      );
    }
  })();
</script>
