---
import Localized from './Localized.astro'
import {DEFAULT_LOCALE, formatPrice, t, type Locale} from '../lib/locale'
import type {HomePageDoc, ServicePackageDoc, SiteSettingsDoc} from '../lib/types'

interface Props {
  home: HomePageDoc | null
  packages: readonly ServicePackageDoc[]
  settings: SiteSettingsDoc | null
  formId?: string
  showHeader?: boolean
}

const {home, packages, settings, formId = 'quoteForm', showHeader = false} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
const copy = home?.quoteForm
const calUrl =
  settings?.calBookingUrl ?? 'https://cal.com/dimitris-geronikolos-z3h6en/chat-for-your-project'
const recaptchaSiteKey = (import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY ?? '').trim()

function packageOptionLabel(pkg: ServicePackageDoc): string {
  const title = t(pkg.title, locale)
  const price = pkg.price != null ? formatPrice(pkg.price, locale) : ''
  return `${title}, ${price}`.trim()
}

const timelineOptions = [
  {value: 'asap', label: copy?.timelineAsap},
  {value: 'soon', label: copy?.timelineSoon},
  {value: 'flexible', label: copy?.timelineFlexible},
]
---

<div class="quote-form-wrap">
  {
    showHeader && copy ? (
      <div class="modal-head" style="border-bottom:none;padding-bottom:0">
        <div>
          <Localized value={copy.title} tag="h2" />
          <Localized value={copy.intro} tag="p" />
        </div>
      </div>
    ) : null
  }

  <form id={formId} class="quote-form" novalidate>
    <div class="form-grid">
      <div class="field">
        <label for={`${formId}-name`}>
          {t(copy?.nameLabel, locale)} <span class="req">*</span>
        </label>
        <input type="text" id={`${formId}-name`} name="name" required autocomplete="name" />
      </div>
      <div class="field">
        <label for={`${formId}-email`}>
          {t(copy?.emailLabel, locale)} <span class="req">*</span>
        </label>
        <input type="email" id={`${formId}-email`} name="email" required autocomplete="email" />
      </div>
      <div class="field">
        <label for={`${formId}-company`}>{t(copy?.companyLabel, locale)}</label>
        <input type="text" id={`${formId}-company`} name="company" autocomplete="organization" />
      </div>
      <div class="field">
        <label for={`${formId}-package`}>
          {t(copy?.packageLabel, locale)} <span class="req">*</span>
        </label>
        <select id={`${formId}-package`} name="package" required>
          <option value="">{t(copy?.packagePlaceholder, locale)}</option>
          {
            packages.map((pkg) => {
              const slug = pkg.slug?.current ?? ''
              return (
                <option value={slug} data-title-el={t(pkg.title, 'el')} data-title-en={t(pkg.title, 'en')}>
                  {packageOptionLabel(pkg)}
                </option>
              )
            })
          }
          <option value="other">{t(copy?.otherPackageLabel, locale)}</option>
        </select>
      </div>
      <div class="field full">
        <label class="check">
          <input type="checkbox" id={`${formId}-hasSite`} name="hasSite" />
          <span>{t(copy?.hasSiteLabel, locale)}</span>
        </label>
      </div>
      <div class="field full hidden" id={`${formId}-urlField`}>
        <label for={`${formId}-url`}>{t(copy?.existingUrlLabel, locale)}</label>
        <input type="url" id={`${formId}-url`} name="existingUrl" placeholder="https://" />
      </div>
      <div class="field full">
        <label for={`${formId}-desc`}>
          {t(copy?.descriptionLabel, locale)} <span class="req">*</span>
        </label>
        <textarea id={`${formId}-desc`} name="description" required></textarea>
      </div>
      <div class="field full">
        <label for={`${formId}-time`}>
          {t(copy?.timelineLabel, locale)} <span class="req">*</span>
        </label>
        <select id={`${formId}-time`} name="timeline" required>
          <option value="">{t(copy?.timelinePlaceholder, locale)}</option>
          {
            timelineOptions.map((option) => (
              <option
                value={option.value}
                data-label-el={t(option.label, 'el')}
                data-label-en={t(option.label, 'en')}
              >
                {t(option.label, locale)}
              </option>
            ))
          }
        </select>
      </div>
    </div>
    <div class="form-foot">
      {
        copy?.submitLabel ? (
          <button type="submit" class="btn btn-primary">{t(copy.submitLabel, locale)}</button>
        ) : null
      }
      {copy?.footnote ? <Localized value={copy.footnote} tag="span" class="note" /> : null}
    </div>
  </form>

  <div class="success hidden" id={`${formId}-success`}>
    <span class="mark">✓</span>
    {copy?.successTitle ? <Localized value={copy.successTitle} tag="h3" /> : null}
    {copy?.successBody ? <Localized value={copy.successBody} tag="p" /> : null}
    <span class="divider"></span>
    {copy?.successCallPrompt ? <Localized value={copy.successCallPrompt} tag="p" /> : null}
    {
      copy?.successCalLabel ? (
        <a class="btn btn-primary" href={calUrl} target="_blank" rel="noopener noreferrer">
          {t(copy.successCalLabel, locale)}
        </a>
      ) : null
    }
  </div>
</div>

<script define:vars={{formId, recaptchaSiteKey}}>
  function loadRecaptchaScript() {
    if (!recaptchaSiteKey) return Promise.resolve()
    if (window.grecaptcha?.execute) return Promise.resolve()
    if (window.__ftiaxesiteRecaptchaLoading) return window.__ftiaxesiteRecaptchaLoading

    window.__ftiaxesiteRecaptchaLoading = new Promise((resolve, reject) => {
      const existing = document.querySelector('script[data-ftiaxesite-recaptcha]')
      if (existing) {
        existing.addEventListener('load', () => resolve())
        existing.addEventListener('error', () => reject(new Error('reCAPTCHA failed to load')))
        return
      }
      const script = document.createElement('script')
      script.src = `https://www.google.com/recaptcha/api.js?render=${encodeURIComponent(recaptchaSiteKey)}`
      script.async = true
      script.dataset.ftiaxesiteRecaptcha = '1'
      script.onload = () => resolve()
      script.onerror = () => reject(new Error('reCAPTCHA failed to load'))
      document.head.appendChild(script)
    })

    return window.__ftiaxesiteRecaptchaLoading
  }

  function whenRecaptchaReady(callback) {
    if (!recaptchaSiteKey) {
      callback()
      return Promise.resolve()
    }
    return loadRecaptchaScript().then(() => {
      return new Promise((resolve) => {
        const finish = () => {
          callback()
          resolve()
        }
        const tryReady = () => {
          if (window.grecaptcha?.execute) {
            window.grecaptcha.ready(finish)
            return true
          }
          return false
        }
        if (tryReady()) return
        let attempts = 0
        const timer = window.setInterval(() => {
          attempts += 1
          if (tryReady() || attempts > 40) {
            window.clearInterval(timer)
            if (attempts > 40) resolve()
          }
        }, 100)
      })
    })
  }

  function executeRecaptcha() {
    return new Promise((resolve, reject) => {
      if (!recaptchaSiteKey) {
        resolve('')
        return
      }
      whenRecaptchaReady(() => {
        if (!window.grecaptcha?.execute) {
          reject(new Error('reCAPTCHA unavailable'))
          return
        }
        window.grecaptcha
          .execute(recaptchaSiteKey, {action: 'quote_submit'})
          .then(resolve)
          .catch(reject)
      }).catch(reject)
    })
  }

  function initQuoteForm(id) {
    const form = document.getElementById(id)
    if (!form || form.dataset.bound === 'true') return
    form.dataset.bound = 'true'

    const hasSite = document.getElementById(`${id}-hasSite`)
    const urlField = document.getElementById(`${id}-urlField`)
    const success = document.getElementById(`${id}-success`)
    const packageSelect = document.getElementById(`${id}-package`)
    const timelineSelect = document.getElementById(`${id}-time`)

    const warmup = () => {
      loadRecaptchaScript().catch(() => {})
    }
    form.addEventListener('focusin', warmup, {once: true})
    form.addEventListener('pointerdown', warmup, {once: true})

    hasSite?.addEventListener('change', () => {
      urlField?.classList.toggle('hidden', !hasSite.checked)
    })

    form.addEventListener('submit', async (event) => {
      event.preventDefault()
      if (!form.reportValidity()) return

      const selectedPackage = packageSelect?.selectedOptions?.[0]
      const selectedTimeline = timelineSelect?.selectedOptions?.[0]
      const lang = document.documentElement.lang === 'en' ? 'en' : 'el'

      let projectType = ''
      if (packageSelect?.value === 'other') {
        projectType = lang === 'en' ? 'Something else, not sure yet' : 'Κάτι άλλο, δεν είμαι σίγουρος'
      } else if (selectedPackage) {
        projectType =
          lang === 'en'
            ? selectedPackage.getAttribute('data-title-en') || selectedPackage.textContent?.trim() || ''
            : selectedPackage.getAttribute('data-title-el') || selectedPackage.textContent?.trim() || ''
      }

      const timeline =
        lang === 'en'
          ? selectedTimeline?.getAttribute('data-label-en') || selectedTimeline?.textContent?.trim() || ''
          : selectedTimeline?.getAttribute('data-label-el') || selectedTimeline?.textContent?.trim() || ''

      const submitBtn = form.querySelector('[type="submit"]')
      if (submitBtn) submitBtn.disabled = true

      try {
        const recaptchaToken = await executeRecaptcha()
        if (recaptchaSiteKey && !recaptchaToken) {
          throw new Error(
            lang === 'en'
              ? 'Security check failed. Please try again.'
              : 'Ο έλεγχος ασφαλείας απέτυχε. Δοκίμασε ξανά.',
          )
        }

        const payload = {
          name: form.querySelector('[name="name"]')?.value?.trim(),
          email: form.querySelector('[name="email"]')?.value?.trim(),
          company: form.querySelector('[name="company"]')?.value?.trim() || undefined,
          projectType,
          hasExistingWebsite: Boolean(hasSite?.checked),
          existingWebsiteUrl: form.querySelector('[name="existingUrl"]')?.value?.trim() || undefined,
          message: form.querySelector('[name="description"]')?.value?.trim(),
          timeline,
          recaptchaToken,
        }

        const response = await fetch('/api/quote-request/', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify(payload),
        })
        const result = await response.json()
        if (!response.ok || !result.success) {
          throw new Error(result.error || 'Submit failed')
        }

        window.dataLayer = window.dataLayer || []
        window.dataLayer.push({
          event: 'quote_form_submit',
          quote_package: packageSelect?.value || '',
        })

        form.classList.add('hidden')
        success?.classList.remove('hidden')
      } catch (error) {
        console.error(error)
        if (submitBtn) submitBtn.disabled = false
        alert(
          error instanceof Error && error.message
            ? error.message
            : document.documentElement.lang === 'en'
              ? 'Something went wrong. Please try again.'
              : 'Κάτι πήγε στραβά. Δοκίμασε ξανά.',
        )
      }
    })
  }

  initQuoteForm(formId)
  document.addEventListener('astro:page-load', () => initQuoteForm(formId))
</script>
