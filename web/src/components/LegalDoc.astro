---
import {DEFAULT_LOCALE, t, type Locale} from '../lib/locale'
import type {LegalDocDoc} from '../lib/types'

interface Props {
  doc: LegalDocDoc | null
}

const {doc} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE

function formatBody(text: string): string {
  return text
    .split(/\n{2,}/)
    .map((block) => block.trim())
    .filter(Boolean)
    .map((block) => {
      if (block.startsWith('## ')) {
        return `<h3>${block.replace(/^##\s+/, '')}</h3>`
      }
      if (block.includes('\n- ')) {
        const [heading, ...rest] = block.split('\n')
        const items = rest.map((line) => `<li>${line.replace(/^-\s+/, '')}</li>`).join('')
        return `${heading ? `<p>${heading}</p>` : ''}<ul>${items}</ul>`
      }
      if (block.startsWith('- ')) {
        const items = block
          .split('\n')
          .map((line) => `<li>${line.replace(/^-\s+/, '')}</li>`)
          .join('')
        return `<ul>${items}</ul>`
      }
      return `<p>${block}</p>`
    })
    .join('')
}

const bodyHtml = formatBody(t(doc?.body, locale))
---

<article class="doc" set:html={bodyHtml} />
