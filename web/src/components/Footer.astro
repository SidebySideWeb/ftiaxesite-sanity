---
import Localized from './Localized.astro'
import type {ServicePackageDoc, SiteSettingsDoc} from '../lib/types'
import {DEFAULT_LOCALE, localizeHref, t, type Locale} from '../lib/locale'

interface Props {
  settings: SiteSettingsDoc | null
  packages: readonly ServicePackageDoc[]
}

const {settings, packages} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
const year = new Date().getFullYear()
const copyright = (settings?.copyrightLine ?? '© {year} ftiaxesite.gr. All rights reserved.').replace(
  '{year}',
  String(year),
)
const phone = settings?.phone?.replace(/\s/g, '') ?? ''
const telHref = phone ? `tel:${phone.startsWith('+') ? phone : `+30${phone.replace(/^0/, '')}`}` : '#'
const homeHref = localizeHref('/', locale)
---

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot">
        <a href={homeHref} class="logo" aria-label="ftiaxesite.gr">
          <img src="/ftiaxesite-logo.svg" alt="ftiaxesite.gr" width="168" height="22" />
        </a>
        <Localized value={settings?.tagline} tag="p" class="tag" />
        {settings?.familyBadge ? <span class="family">{settings.familyBadge}</span> : null}
      </div>
      <div class="foot">
        <Localized value={settings?.footerServicesTitle} tag="h2" />
        {
          packages.map((pkg) => (
            <a href={localizeHref('#pricing', locale)}>{t(pkg.title, locale)}</a>
          ))
        }
      </div>
      <div class="foot">
        <Localized value={settings?.footerContactTitle} tag="h2" />
        {settings?.email ? <a href={`mailto:${settings.email}`}>{settings.email}</a> : null}
        {settings?.phone ? <a href={telHref}>{settings.phone}</a> : null}
        <Localized value={settings?.addressLine} tag="span" class="addr" />
        {
          settings?.navCtaLabel ? (
            <button type="button" class="linklike" data-open="quoteModal">
              {t(settings.navCtaLabel, locale)}
            </button>
          ) : null
        }
      </div>
    </div>
    <div class="foot-bottom">
      <span>{copyright}</span>
      <span class="legal-links">
        {
          settings?.privacyLinkLabel ? (
            <a href={localizeHref('/privacy/', locale)}>{t(settings.privacyLinkLabel, locale)}</a>
          ) : null
        }
        {
          settings?.cookiesLinkLabel ? (
            <a href={localizeHref('/cookies/', locale)}>{t(settings.cookiesLinkLabel, locale)}</a>
          ) : null
        }
        {
          settings?.cookieSettingsLabel ? (
            <button type="button" id="cookieSettingsBtn">{t(settings.cookieSettingsLabel, locale)}</button>
          ) : null
        }
      </span>
    </div>
  </div>
</footer>

<script>
  document.getElementById('cookieSettingsBtn')?.addEventListener('click', () => {
    window.__ftiaxesiteShowCookiePreferences?.()
  })
</script>
