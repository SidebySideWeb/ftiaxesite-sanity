---
import '../styles/fluent-form.css';

import { fetchFluentForm, getWordPressOrigin, parseFluentFormId } from '../lib/cms';
import { DEFAULT_LOCALE, localeToWpmlCode, type SiteLocale } from '../lib/i18n';

interface Props {
  readonly shortcode?: string;
  readonly locale?: SiteLocale;
}

const shortcode = Astro.props.shortcode?.trim() ?? '';
const locale = Astro.props.locale ?? DEFAULT_LOCALE;
const formId = parseFluentFormId(shortcode);
const wpOrigin = getWordPressOrigin();
const formPayload = formId ? await fetchFluentForm(formId, locale) : null;
const hasEmbed = Boolean(formPayload?.html && formId && wpOrigin);
const assetsJson = hasEmbed
  ? JSON.stringify({
      styles: formPayload?.styles ?? [],
      scripts: formPayload?.scripts ?? [],
      inlineScripts: formPayload?.inlineScripts ?? [],
    })
  : '';
const wpmlLang = localeToWpmlCode(locale);
---

{
  hasEmbed ? (
    <div
      class="fluent-form-embed"
      data-fluent-form-embed
      data-form-id={formId}
      data-wp-origin={wpOrigin}
      data-lang={wpmlLang}
    >
      <div class="fluent-form-html" set:html={formPayload?.html} />
      <script is:inline type="application/json" data-fluent-form-assets set:html={assetsJson} />
    </div>
  ) : (
    <slot />
  )
}

<script>
  interface FluentFormAsset {
    handle: string;
    src: string;
  }

  interface FluentFormInlineScript {
    handle: string;
    data: string;
  }

  interface FluentFormAssets {
    styles: FluentFormAsset[];
    scripts: FluentFormAsset[];
    inlineScripts: FluentFormInlineScript[];
  }

  const loadedScripts = new Set<string>();
  const loadedStyles = new Set<string>();

  function isFluentFormThemeStylesheet(handle: string, src: string): boolean {
    if (handle === 'fluent-form-styles' || handle === 'fluentform-public-default') {
      return true;
    }
    return src.includes('/fluentform/assets/css/') && src.endsWith('.css');
  }

  function loadStyle(src: string, handle: string): void {
    if (isFluentFormThemeStylesheet(handle, src)) {
      return;
    }
    if (loadedStyles.has(handle) || document.querySelector(`link[data-ff="${handle}"]`)) {
      loadedStyles.add(handle);
      return;
    }
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = src;
    link.dataset.ff = handle;
    document.head.appendChild(link);
    loadedStyles.add(handle);
  }

  function loadScript(src: string, handle: string): Promise<void> {
    if (loadedScripts.has(handle) || document.querySelector(`script[data-ff="${handle}"]`)) {
      loadedScripts.add(handle);
      return Promise.resolve();
    }
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = src;
      script.dataset.ff = handle;
      script.async = false;
      script.onload = () => {
        loadedScripts.add(handle);
        resolve();
      };
      script.onerror = () => reject(new Error(`Failed to load Fluent Forms script: ${handle}`));
      document.body.appendChild(script);
    });
  }

  function runInlineScript(code: string): void {
    const script = document.createElement('script');
    script.text = code;
    document.body.appendChild(script);
  }

  async function loadAssetsFromJson(assets: FluentFormAssets): Promise<void> {
    for (const style of assets.styles) {
      if (!isFluentFormThemeStylesheet(style.handle, style.src)) {
        loadStyle(style.src, style.handle);
      }
    }
    for (const script of assets.scripts) {
      const inline = assets.inlineScripts.find((row) => row.handle === script.handle);
      if (inline) {
        runInlineScript(inline.data);
      }
      await loadScript(script.src, script.handle);
    }
    for (const inline of assets.inlineScripts) {
      if (assets.scripts.some((script) => script.handle === inline.handle)) {
        continue;
      }
      runInlineScript(inline.data);
    }
  }

  async function fetchAssetsFromApi(origin: string, formId: string, lang: string): Promise<FluentFormAssets | null> {
    try {
      const url = new URL(`${origin}/wp-json/fti/v1/forms/${formId}`);
      url.searchParams.set('lang', lang);
      const response = await fetch(url.toString(), {
        headers: { Accept: 'application/json' },
      });
      if (!response.ok) {
        return null;
      }
      const payload = (await response.json()) as FluentFormAssets & { html?: string };
      if (!payload || typeof payload !== 'object') {
        return null;
      }
      return {
        styles: Array.isArray(payload.styles)
          ? payload.styles.filter((row) => !isFluentFormThemeStylesheet(row.handle, row.src))
          : [],
        scripts: Array.isArray(payload.scripts) ? payload.scripts : [],
        inlineScripts: Array.isArray(payload.inlineScripts) ? payload.inlineScripts : [],
      };
    } catch {
      return null;
    }
  }

  async function initFluentFormEmbed(root: HTMLElement): Promise<void> {
    const formId = root.dataset.formId;
    const wpOrigin = root.dataset.wpOrigin;
    const lang = root.dataset.lang ?? 'el';
    if (!formId || !wpOrigin) {
      return;
    }

    const assetsNode = root.querySelector('[data-fluent-form-assets]');
    let assets: FluentFormAssets | null = null;

    if (assetsNode?.textContent) {
      try {
        assets = JSON.parse(assetsNode.textContent) as FluentFormAssets;
      } catch {
        assets = null;
      }
    }

    if (!assets) {
      assets = await fetchAssetsFromApi(wpOrigin, formId, lang);
    }

    if (!assets) {
      return;
    }

    await loadAssetsFromJson(assets);
    root.classList.add('fluent-form-ready');
  }

  document.querySelectorAll<HTMLElement>('[data-fluent-form-embed]').forEach((root) => {
    void initFluentFormEmbed(root);
  });
</script>
