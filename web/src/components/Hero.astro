---
import Localized from './Localized.astro'
import PriceReceipt from './PriceReceipt.astro'
import type {HomePageDoc, ServicePackageDoc} from '../lib/types'
import {DEFAULT_LOCALE, localizeHref, t, type Locale} from '../lib/locale'

interface Props {
  home: HomePageDoc | null
  packages: readonly ServicePackageDoc[]
}

const {home, packages} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
---

<span id="top"></span>

<section class="hero">
  <div class="wrap hero-grid">
    <div class="reveal">
      <Localized value={home?.heroEyebrow} tag="span" class="eyebrow" />
      <h1>
        <span>{t(home?.heroHeading, locale)}</span>{' '}
        <span class="hl">{t(home?.heroHighlight, locale)}</span>.
      </h1>
      <Localized value={home?.heroBody} tag="p" class="lead" />
      <div class="hero-cta">
        <a href={localizeHref('#pricing', locale)} class="btn btn-primary">
          {t(home?.ctaPrimaryLabel, locale)}
        </a>
        <button type="button" class="btn btn-ghost" data-open="quoteModal">
          {t(home?.ctaSecondaryLabel, locale)}
        </button>
      </div>
      {
        home?.heroToolsLine ? (
          <div class="tools">
            <span class="dot"></span><span>{home.heroToolsLine}</span>
          </div>
        ) : null
      }
    </div>
    <div class="reveal">
      <PriceReceipt packages={packages} badge={home?.receiptBadge} />
    </div>
  </div>
</section>
