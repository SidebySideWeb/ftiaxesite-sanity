---
import type {NavLink, SiteSettingsDoc} from '../lib/types'
import {
  alternateLocalePath,
  DEFAULT_LOCALE,
  localizeHref,
  t,
  type Locale,
} from '../lib/locale'

interface Props {
  settings: SiteSettingsDoc | null
}

const {settings} = Astro.props
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE
const navLinks = settings?.navLinks ?? []
const ctaLabel = settings?.navCtaLabel
const homeHref = localizeHref('/', locale)
const publicPath = Astro.locals.publicPath || Astro.url.pathname
const elHref = alternateLocalePath(publicPath, 'el')
const enHref = alternateLocalePath(publicPath, 'en')
---

<header class="nav">
  <div class="wrap nav-inner">
    <a href={homeHref} class="logo" aria-label="ftiaxesite.gr">
      <img
        src="/ftiaxesite-logo.svg"
        alt="ftiaxesite.gr"
        width="168"
        height="22"
        decoding="async"
        fetchpriority="high"
      />
    </a>

    <nav class="nav-links" id="primaryNav" aria-label="Primary">
      {
        navLinks.map((link: NavLink) => (
          <a class="nl" href={localizeHref(link.href ?? '#', locale)}>
            {t(link.label, locale)}
          </a>
        ))
      }
      <div class="lang lang-mobile" role="group" aria-label="Language">
        <a href={elHref} class={locale === 'el' ? 'active' : undefined} hreflang="el" lang="el">EL</a>
        <a href={enHref} class={locale === 'en' ? 'active' : undefined} hreflang="en" lang="en">EN</a>
      </div>
    </nav>

    <div class="nav-right">
      <div class="lang lang-desktop" role="group" aria-label="Language">
        <a href={elHref} class={locale === 'el' ? 'active' : undefined} hreflang="el" lang="el">EL</a>
        <a href={enHref} class={locale === 'en' ? 'active' : undefined} hreflang="en" lang="en">EN</a>
      </div>
      {
        ctaLabel ? (
          <button type="button" class="btn btn-primary btn-sm nav-cta-desktop" data-open="quoteModal">
            {t(ctaLabel, locale)}
          </button>
        ) : null
      }
      <button
        type="button"
        class="burger"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="primaryNav"
        id="navBurger"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

{
  ctaLabel ? (
    <div class="sticky-cta" id="stickyCta" role="region" aria-label="Quote CTA">
      <button type="button" class="btn btn-primary" data-open="quoteModal">
        {t(ctaLabel, locale)}
      </button>
    </div>
  ) : (
    <div class="sticky-cta" id="stickyCta" role="region" aria-label="Quote CTA">
      <button type="button" class="btn btn-primary" data-open="quoteModal">
        {locale === 'en' ? 'Get a quote' : 'Ζήτησε Προσφορά'}
      </button>
    </div>
  )
}

<script>
  const burger = document.getElementById('navBurger')
  const nav = document.getElementById('primaryNav')

  function closeMenu() {
    nav?.classList.remove('is-open')
    burger?.setAttribute('aria-expanded', 'false')
    document.body.classList.remove('nav-open')
  }

  function openMenu() {
    nav?.classList.add('is-open')
    burger?.setAttribute('aria-expanded', 'true')
    document.body.classList.add('nav-open')
  }

  burger?.addEventListener('click', () => {
    if (nav?.classList.contains('is-open')) closeMenu()
    else openMenu()
  })

  nav?.querySelectorAll('a.nl').forEach((link) => {
    link.addEventListener('click', () => closeMenu())
  })

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu()
  })
</script>
