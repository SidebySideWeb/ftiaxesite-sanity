---
import Analytics from '../components/Analytics.astro';

interface Props {
  readonly title: string;
  readonly description: string;
  readonly canonicalPath?: string;
  readonly ogImageUrl?: string | null;
}

const { title, description, canonicalPath, ogImageUrl } = Astro.props;

const siteUrl = (import.meta.env.SITE_URL ?? '').replace(/\/$/, '');
const siteName = import.meta.env.SITE_NAME ?? 'Astro + WordPress';

const canonicalUrl = ((): string | undefined => {
  if (siteUrl.length === 0) {
    return undefined;
  }
  if (!canonicalPath) {
    return undefined;
  }
  const normalizedPath = canonicalPath.startsWith('/') ? canonicalPath : `/${canonicalPath}`;
  return `${siteUrl}${normalizedPath}`;
})();

const pageTitle = `${title} · ${siteName}`;
---

<!doctype html>
<html class="h-full" lang="en">
  <head>
    <Analytics placement="head" />
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <meta content={description} name="description" />
    <meta content={siteName} name="author" />
    <title>{pageTitle}</title>
    {canonicalUrl ? <link href={canonicalUrl} rel="canonical" /> : null}
    <meta content={pageTitle} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content="website" property="og:type" />
    {canonicalUrl ? <meta content={canonicalUrl} property="og:url" /> : null}
    {ogImageUrl ? <meta content={ogImageUrl} property="og:image" /> : null}
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={pageTitle} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    {ogImageUrl ? <meta content={ogImageUrl} name="twitter:image" /> : null}
    <link href="/favicon.png" rel="icon" type="image/png" />
    <link href="/favicon.png" rel="apple-touch-icon" />
  </head>
  <body class="min-h-full bg-slate-50 text-slate-900 antialiased">
    <Analytics placement="body" />
    <a
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-3 focus:py-2 focus:text-sm focus:font-semibold focus:text-slate-900 focus:shadow-lg"
      href="#main-content"
    >
      Skip to content
    </a>
    <div class="flex min-h-full flex-col">
      <header class="border-b border-slate-200 bg-white">
        <div class="mx-auto flex w-full max-w-6xl flex-col gap-4 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
          <a class="text-lg font-semibold tracking-tight text-slate-900" href="/">{siteName}</a>
          <nav aria-label="Primary" class="flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium">
            <a class="text-slate-700 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-600" href="/">Home</a>
            <a class="text-slate-700 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-600" href="/blog/">Blog</a>
          </nav>
        </div>
      </header>
      <main class="flex-1" id="main-content">
        <slot />
      </main>
      <footer class="border-t border-slate-200 bg-white">
        <div class="mx-auto flex w-full max-w-6xl flex-col gap-2 px-4 py-8 text-sm text-slate-600 sm:px-6 lg:px-8">
          <p class="font-medium text-slate-800">{siteName}</p>
          <p>Powered by Astro and a headless WordPress CMS.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
