{
  "name": "sanity-astro-starter",
  "private": true,
  "description": "Reusable Sanity Studio + Astro starter (ftiaxesite stack)",
  "scripts": {
    "new-project": "node scripts/new-project.mjs",
    "seed": "npm run seed --prefix studio-ftiaxesite",
    "dev:studio": "npm run dev --prefix studio-ftiaxesite",
    "dev:web": "npm run dev --prefix web",
